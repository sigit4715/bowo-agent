# BOWO Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ─── Hermes ────────────────────────────────────────────────────────────────────
# Path to the Hermes CLI binary
HERMES_PATH=/opt/hermes/bin/hermes

# ─── Server ────────────────────────────────────────────────────────────────────
# HTTP port the BOWO server listens on
BOWO_PORT=3001

# Log verbosity: debug | info | warn | error
BOWO_LOG_LEVEL=info

# Secret key for session/auth — change this in production!
BOWO_SECRET=change-me-in-production

# ─── API Keys ──────────────────────────────────────────────────────────────────
# LLM provider keys (set the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Storage ───────────────────────────────────────────────────────────────────
# Path to the SQLite database directory (relative to project root)
BOWO_DB_PATH=output/database

# Cache time-to-live in seconds (5 minutes default)
BOWO_CACHE_TTL=300
