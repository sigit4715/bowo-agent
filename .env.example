# 🤖 BOWO — Environment Configuration
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════
# LLM Provider Configuration
# ═══════════════════════════════════════════════
# Set BOWO_LLM_PROVIDER to choose, or just set
# the API key and BOWO auto-detects the provider.
# ═══════════════════════════════════════════════

# Quick setup (auto-detect from API key):
# BOWO_LLM_PROVIDER=openai
# BOWO_LLM_MODEL=gpt-4o-mini
# BOWO_LLM_API_KEY=sk-your-key-here

# ── OpenAI ──
# OPENAI_API_KEY=sk-your-key

# ── OpenRouter (multi-model hub) ──
# OPENROUTER_API_KEY=sk-or-your-key

# ── Anthropic ──
# ANTHROPIC_API_KEY=sk-ant-your-key

# ── DeepSeek ──
# DEEPSEEK_API_KEY=your-key

# ── Groq (fast inference) ──
# GROQ_API_KEY=gsk_your-key

# ── xAI (Grok) ──
# XAI_API_KEY=xai-your-key

# ── Google Gemini ──
# GOOGLE_API_KEY=your-key

# ── Together AI ──
# TOGETHER_API_KEY=your-key

# ── Fireworks AI ──
# FIREWORKS_API_KEY=your-key

# ── Ollama (local, no key needed) ──
# BOWO_LLM_PROVIDER=ollama
# BOWO_LLM_MODEL=llama3.1

# ── LM Studio (local, no key needed) ──
# BOWO_LLM_PROVIDER=lmstudio

# ── Custom endpoint (any OpenAI-compatible API) ──
# BOWO_LLM_PROVIDER=custom-name
# BOWO_LLM_BASE_URL=https://my-api.example.com/v1
# BOWO_LLM_API_KEY=my-key
# BOWO_LLM_MODEL=my-model

# Server Configuration
PORT=3001
NODE_ENV=development
